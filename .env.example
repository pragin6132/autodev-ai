# ==============================================================================
# AutoDev AI - Environment Variables Template
# Copy this file to '.env' and fill in your settings.
# ==============================================================================

# General Configuration
APP_ENV=development
DEBUG=true
SECRET_KEY=generate-a-secure-random-key-for-production

# Agent Configurations
LLM_PROVIDER=openai  # openai, anthropic, gemini, ollama
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# Database settings
DATABASE_URL=postgresql://autodev:autodev_password@localhost:5432/autodev_db
# For local fallback development: sqlite:///./autodev.db

# MCP settings
MCP_SERVER_CONFIG_PATH=./config/mcp_servers.json
MCP_TIMEOUT_SECONDS=30

# Backend service port
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Frontend service port
FRONTEND_PORT=5173

# Docker specific settings
POSTGRES_DB=autodev_db
POSTGRES_USER=autodev
POSTGRES_PASSWORD=autodev_password
